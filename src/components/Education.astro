---
import Section from "./Section.astro";
import type { EducationProps } from "@types";

interface Props {
  education: EducationProps[];
}

const { education } = Astro.props;
---

<Section text="Education" href="education">
  <div class="relative">
    <!-- Vertical timeline line -->
    <div class="absolute top-0 left-4 h-full w-px bg-neutral/20"></div>

    <div class="space-y-10">
      {
        education.map(({ degree, institution, location, year, detail }, index) => (
          <div class="relative flex gap-8">
            <!-- Timeline dot -->
            <div class="relative z-10 mt-1 flex h-8 w-8 shrink-0 items-center justify-center rounded-full border border-neutral/30 bg-black">
              {index === 0 ? (
                <div class="h-2.5 w-2.5 rounded-full bg-primary" />
              ) : (
                <div class="h-2 w-2 rounded-full bg-neutral/50" />
              )}
            </div>

            <!-- Card -->
            <div class="flex-1 rounded-2xl border border-neutral/20 bg-white/5 p-6">
              <div class="mb-3 flex flex-wrap items-start justify-between gap-2">
                <span class="rounded-full border border-neutral/30 px-3 py-0.5 text-xs text-neutral">
                  {year}
                </span>
                {index === 0 && (
                  <span class="rounded-full bg-primary/20 px-3 py-0.5 text-xs font-medium text-primary">
                    Latest
                  </span>
                )}
              </div>
              <h3 class="mb-1 font-serif text-lg font-semibold text-white">
                {degree}
              </h3>
              <p class="text-sm text-neutral">{institution}</p>
              <p class="text-xs text-neutral/60">{location}</p>
              {detail && (
                <p class="mt-3 text-sm font-medium text-primary">{detail}</p>
              )}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</Section>
