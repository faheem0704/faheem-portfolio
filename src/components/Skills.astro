---
import Section from "./Section.astro";
import type { SkillCategoryProps } from "@types";

interface Props {
  skills: SkillCategoryProps[];
}

const { skills } = Astro.props;
---

<Section text="Skills" href="skills">
  <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
    {
      skills.map(({ category, icon, skills }) => (
        <div class="rounded-2xl border border-neutral/20 bg-white/5 p-6">
          <div class="mb-4 flex items-center gap-3">
            <span class="font-mono text-lg text-primary">{icon}</span>
            <h3 class="font-serif text-lg font-semibold text-white">{category}</h3>
          </div>
          <div class="flex flex-wrap gap-2">
            {skills.map((skill) => (
              <span class="rounded-full border border-neutral/30 px-3 py-1 text-xs text-neutral">
                {skill}
              </span>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</Section>
